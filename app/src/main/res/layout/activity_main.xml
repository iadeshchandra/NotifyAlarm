<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgLight">

    <!-- TOP APP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/primaryGreen"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔔 Notif Alarm Pro"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold"/>
        <Switch
            android:id="@+id/masterSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:thumbTint="#FFFFFF"
            android:trackTint="#80FFFFFF"/>
    </LinearLayout>

    <!-- CONTENT AREA -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ══ HOME PANEL ══════════════════════════════════════════════ -->
        <ScrollView android:id="@+id/panelHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- STATUS CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/activeGreen"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView android:id="@+id/tvStatusTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🟢  Monitoring Active"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                        <TextView android:id="@+id/tvStatusDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Watching for keywords in your selected apps"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:layout_marginTop="6dp"/>
                        <!-- STOP & SNOOZE buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="14dp"
                            android:weightSum="2">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStopAlarm"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="1"
                                android:text="⏹ STOP"
                                android:textStyle="bold"
                                android:backgroundTint="#E53935"
                                android:layout_marginEnd="6dp"
                                android:visibility="gone"
                                app:cornerRadius="10dp"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSnooze"
                                android:layout_width="0dp"
                                android:layout_height="46dp"
                                android:layout_weight="1"
                                android:text="💤 Snooze"
                                android:backgroundTint="#FF8F00"
                                android:layout_marginStart="6dp"
                                android:visibility="gone"
                                app:cornerRadius="10dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- STATS ROW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">
                            <TextView android:id="@+id/tvAlarmCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 alarms triggered"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/primaryGreen"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total alarms"
                                android:textSize="11sp"
                                android:textColor="@color/textMuted"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">
                            <TextView android:id="@+id/tvLastTrigger"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No alarms yet"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/primaryGreen"
                                android:gravity="center"
                                android:visibility="gone"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Last alarm"
                                android:textSize="11sp"
                                android:textColor="@color/textMuted"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- TEST BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestAlarm"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="▶  TEST ALARM"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#FF8F00"
                    app:cornerRadius="12dp"/>

                <!-- QUICK TIPS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#EFF6FF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡 Quick Tips"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1E40AF"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• Tap Apps tab to choose which apps to monitor\n• Tap Keywords tab to add unlimited keywords\n• History tab shows all past alarms\n• Disable battery optimization for best results"
                            android:textSize="12sp"
                            android:textColor="#3B82F6"
                            android:lineSpacingMultiplier="1.5"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

        <!-- ══ APPS PANEL ══════════════════════════════════════════════ -->
        <ScrollView android:id="@+id/panelApps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select apps to monitor"
                    android:textSize="14sp"
                    android:textColor="@color/textMuted"
                    android:layout_marginBottom="12dp"/>

                <!-- ALL APPS CARD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFBEB">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📲  Monitor ALL Apps" android:textSize="15sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Trigger alarm from any app's notifications"
                                android:textSize="12sp" android:textColor="@color/textMuted"/>
                        </LinearLayout>
                        <Switch android:id="@+id/switchAllApps" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:id="@+id/appListContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

        <!-- ══ KEYWORDS PANEL ══════════════════════════════════════════ -->
        <ScrollView android:id="@+id/panelKeywords"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Add keyword input -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:id="@+id/tvKeywordCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="16 keywords active"
                            android:textSize="12sp"
                            android:textColor="@color/textMuted"
                            android:layout_marginBottom="10dp"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Add keyword..."
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etKeyword"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:imeOptions="actionDone"
                                    android:inputType="text"/>
                            </com.google.android.material.textfield.TextInputLayout>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAddKeyword"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_gravity="center_vertical"
                                android:text="ADD"
                                android:backgroundTint="@color/primaryGreen"
                                app:cornerRadius="8dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Keyword chips container -->
                <LinearLayout android:id="@+id/keywordChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </ScrollView>

        <!-- ══ HISTORY PANEL ══════════════════════════════════════════ -->
        <ScrollView android:id="@+id/panelHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Alarm History"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <Button
                        android:id="@+id/btnClearHistory"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Clear"
                        android:textSize="12sp"
                        android:backgroundTint="#EF4444"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <TextView android:id="@+id/tvNoHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No alarm history yet.\nAlarms will appear here when triggered."
                    android:textColor="@color/textMuted"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:layout_marginTop="60dp"
                    android:visibility="visible"/>

                <LinearLayout android:id="@+id/historyList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:weightSum="5">

        <!-- Home -->
        <LinearLayout android:id="@+id/tabHome"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏠" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home"
                android:textSize="10sp" android:textStyle="bold" android:textColor="@color/primaryGreen"/>
        </LinearLayout>

        <!-- Apps -->
        <LinearLayout android:id="@+id/tabApps"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📱" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Apps"
                android:textSize="10sp" android:textStyle="bold" android:textColor="@color/textMuted"/>
        </LinearLayout>

        <!-- Keywords -->
        <LinearLayout android:id="@+id/tabKeywords"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔑" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Keywords"
                android:textSize="10sp" android:textStyle="bold" android:textColor="@color/textMuted"/>
        </LinearLayout>

        <!-- History -->
        <LinearLayout android:id="@+id/tabHistory"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📋" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History"
                android:textSize="10sp" android:textStyle="bold" android:textColor="@color/textMuted"/>
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout android:id="@+id/tabSettings"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚙️" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings"
                android:textSize="10sp" android:textStyle="bold" android:textColor="@color/textMuted"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
